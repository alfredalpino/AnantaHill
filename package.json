{
  "name": "ananta",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "node scripts/ensure-database.mjs && next build",
    "start": "next start",
    "lint": "eslint",
    "db:ensure": "node scripts/ensure-database.mjs",
    "db:push": "drizzle-kit push",
    "db:local:up": "docker compose -f docker-compose.postgres.yml --env-file docker/postgres.local.env up -d",
    "db:local:down": "docker compose -f docker-compose.postgres.yml --env-file docker/postgres.local.env down",
    "db:local:push": "node scripts/with-local-database-url.mjs npx drizzle-kit push --force",
    "db:local:extras": "node scripts/with-local-database-url.mjs node scripts/run-local-db-extras.mjs",
    "db:local:init": "node scripts/ensure-database.mjs"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.14.0",
    "motion-dom": "^12.38.0",
    "next": "16.2.4",
    "postgres": "^3.4.8",
    "react": "19.2.4",
    "react-datepicker": "^9.1.0",
    "react-dom": "19.2.4",
    "react-icons": "^5.6.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^6.0.3"
  }
}
