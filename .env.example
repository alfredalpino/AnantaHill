# Quote values — unquoted "&" is truncated by many loaders (systemd, shell export), breaking Petpooja auth.
PETPOOJA_CALLBACK_AUTH_BEARER="Bearer petpooja:gCOg6CVq7jwG7rxXGlclFR"
PETPOOJA_CALLBACK_HEADER_NAME="x-petpooja-gCOg6CVq7jwG7rxXGlclFR"
PETPOOJA_CALLBACK_HEADER_VALUE="petpooja:gCOg6CVq7jwG7rxXGlclFR"
APP_AUTH_HEADER="Authorization: Bearer petpooja:gCOg6CVq7jwG7rxXGlclFR"

