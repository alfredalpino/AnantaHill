# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Local Docker Postgres (docker-compose.postgres.yml / PM2 tathastu-postgres). Same values as docker/postgres.local.env
# One-shot: npm run db:local:init   (Compose + drizzle push + btree_gist / indexes)
# Or stepwise: npm run db:local:up && npm run db:local:push && npm run db:local:extras
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=tathastu
PGHOST=127.0.0.1
PGPORT=5433
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=tathastu
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/tathastu?sslmode=disable

# MSG91 Config for OTP verification
NEXT_PUBLIC_MSG91_WIDGET_ID=
NEXT_PUBLIC_MSG91_TOKEN_AUTH=
NEXT_PUBLIC_MSG91_AUTHKEY=

# MSG91 Config for OTP verification (server-side)
MSG91_WIDGET_ID=
MSG91_TOKEN_AUTH=
MSG91_AUTHKEY=
MSG91_TEMPLATE_ID=

# Petpooja API Configs
PETPOOJA_APP_KEY=
PETPOOJA_APP_SECRET=
PETPOOJA_ACCESS_TOKEN=
PETPOOJA_REST_ID=
PETPOOJA_CALLBACK_URL=https://tathastufarm.com/api/petpooja/order-status

# Petpooja Save Order URL
PETPOOJA_SAVE_ORDER_URL=https://pponlineordercb.petpooja.com/save_order
PETPOOJA_RIDER_STATUS_UPDATE_URL=https://pponlineordercb.petpooja.com/rider_status_update
PETPOOJA_UPDATE_ORDER_STATUS_URL=https://pponlineordercb.petpooja.com/update_order_status
PETPOOJA_PUSH_MENU_URL=https://tathastufarm.com/api/petpooja/pushmenu_endpoint

# Quote values — unquoted "&" is truncated by many loaders (systemd, shell export), breaking Petpooja auth.
PETPOOJA_CALLBACK_AUTH_BEARER="Bearer petpooja:your-callback-secret"
PETPOOJA_CALLBACK_HEADER_NAME="x-petpooja-your-callback-secret"
PETPOOJA_CALLBACK_HEADER_VALUE="petpooja:your-callback-secret"
APP_AUTH_HEADER="Authorization: Bearer petpooja:your-callback-secret"

AUTH_SESSION_SECRET=

# CheckinCloud API Configs
CHECKINCLOUD_ENABLED=1
CHECKINCLOUD_BASE_URL=https://checkincloud.in/hotelws/tathabook.php
CHECKINCLOUD_APIPASS=
CHECKINCLOUD_UNIQUECD=
CHECKINCLOUD_USER_ID=0000000032
CHECKINCLOUD_CITYCD=1
CHECKINCLOUD_RESERVPLANCD=1
CHECKINCLOUD_TEST_BOOKADD=0

# Razorpay API Configs (live)
key_id=
key_secret=

# Razorpay Test API Configs
rzp_test_key_id=
rzp_test_key_secret=

# Keep unset/0 in production to enforce payment-first order creation.
ALLOW_DIRECT_FOOD_ORDER_CREATE=0

# Deployment webhook security
DEPLOY_WEBHOOK_SECRET=
DEPLOY_WEBHOOK_PORT=9000
DEPLOY_APP_DIR=/var/www/tathastu/tathastu-farm
DEPLOY_SCRIPT=./scripts/vps/deploy.sh
PM2_APP_NAME=tathastu-farm
DEPLOY_BRANCH=main
APP_DIR=/var/www/tathastu/tathastu-farm

# Google Sign In Configs
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://tathastufarm.com/auth/v1/callback

# Telegram notifications (keep secret; do not share in chat)
TELEGRAM_BOT_TOKEN=
TELEGRAM_GROUP_CHAT_ID=

# Hidden 7-character test coupon for live checkout (98% off subtotal; leaves a small Razorpay charge).
# Food orders only — does not apply to room booking unless the same code is also set as SECRET_ROOM_TEST_COUPON.
SECRET_FULL_DISCOUNT_COUPON=

# Room booking only: 7-character secret test coupon (99.9% off stay subtotal before GST; QA / Razorpay smoke).
SECRET_ROOM_TEST_COUPON=
