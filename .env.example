# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Local Docker Postgres (docker-compose.postgres.yml / PM2 tathastu-postgres). Same values as docker/postgres.local.env
# One-shot: npm run db:local:init   (Compose + drizzle push + btree_gist / indexes)
# Or stepwise: npm run db:local:up && npm run db:local:push && npm run db:local:extras
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5434
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ananta
PGHOST=127.0.0.1
PGPORT=5434
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=ananta
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5434/ananta?sslmode=disable

# MSG91 Config for OTP verification
; NEXT_PUBLIC_MSG91_WIDGET_ID=
; NEXT_PUBLIC_MSG91_TOKEN_AUTH=
; NEXT_PUBLIC_MSG91_AUTHKEY=

# MSG91 Config for OTP verification (server-side)
; MSG91_WIDGET_ID=
; MSG91_TOKEN_AUTH=
; MSG91_AUTHKEY=
; MSG91_TEMPLATE_ID=

